{
  "manifestVersion": 4,
  "id": "da32e34a",
  "name": "MockVault",
  "version": "1.0.0",
  "main": "index.html",
  "host": {
    "app": "PS",
    "minVersion": "22.0.0",
    "data": {
      "apiVersion": 2
    }
  },
  "entrypoints": [{
    "type": "panel",
    "id": "mockupPanel",
    "label": {
      "default": "MockVault"
    },
    "minimumSize": { "width": 280, "height": 400 },
    "maximumSize": { "width": 800, "height": 2000 },
    "preferredDockedSize": { "width": 400, "height": 800 },
    "preferredFloatingSize": { "width": 400, "height": 800 },
    "icons": [{
      "path": "icons/dark.png",
      "species": ["chrome"],
      "width": 23,
      "height": 23,
      "scale": [1, 2],
      "theme": ["dark", "darkest"]
    }, {
      "path": "icons/light.png",
      "species": ["chrome"],
      "width": 23,
      "height": 23,
      "scale": [1, 2],
      "theme": ["lightest", "light"]
    }]
  }],
  "icons": [{
    "path": "icons/dark.png",
    "width": 23,
    "height": 23,
    "scale": [1, 2],
    "theme": ["darkest", "dark", "medium"]
  }, {
    "path": "icons/light.png",
    "width": 23,
    "height": 23,
    "scale": [1, 2],
    "theme": ["lightest", "light"]
  }],
  "requiredPermissions": {
    "localFileSystem": "request"
  }
}
